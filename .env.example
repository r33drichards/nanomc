# NanoMC Configuration

# Assistant name (trigger word in group chats)
ASSISTANT_NAME=NanoMC

# Minecraft MCP server
MC_MCP_ENABLED=1
MC_HOST=44.236.190.147
MC_PORT=25565
MC_USERNAME=nanomc-bot
MC_AUTH=offline

# CLI channel (set to 1 for local testing without messaging platforms)
CLI_CHANNEL=1

# Container settings
CONTAINER_IMAGE=nanomc-agent:latest
CONTAINER_TIMEOUT=1800000
MAX_CONCURRENT_CONTAINERS=5

# Anthropic API key (used by credential proxy, never exposed to containers)
ANTHROPIC_API_KEY=sk-ant-...
