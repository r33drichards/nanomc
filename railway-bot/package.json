{
  "name": "nanomc-irc",
  "version": "0.3.0",
  "description": "NanoClaw Railway Bot — Full orchestrator with IRC channel, Vercel AI SDK + Bedrock + Minecraft MCP",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc && cd agent-runner && npm run build",
    "build:host": "tsc",
    "build:agent": "cd agent-runner && npm run build",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "postinstall": "cd agent-runner && npm install"
  },
  "dependencies": {
    "better-sqlite3": "^11.8.1",
    "cron-parser": "^5.5.0",
    "irc-framework": "^4.13.1",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=20"
  }
}
